      {# Convert valid states to float numbers and calculate the average #}
      Over the last day the average house temperature has been {{ valid_temps | map('float') | average | round(1) }} degrees C
    {% else %}
      {# If all sensors are invalid, set the sensor state to 'unavailable' #}
      unavailable
    {% endif %} {% set sorted_list = expand(sensors)
      | selectattr('state', 'is_number')
      | sort(attribute='state', reverse=true) %}
    {% set max_sensor = sorted_list | first %} {% set max_area =
    area_name(max_sensor.entity_id) %} {% set min_sensor = sorted_list | last %}
    {% set min_area = area_name(min_sensor.entity_id) %} The hottest room was {{
    max_area | default('unavailable') }} at {{ max_sensor.state | round(1) |
    default('unavailable') }} degrees C and the coolest was {{ min_area |
    default('unavailable') }} at {{ min_sensor.state | round(1) |
    default('unavailable') }}
